datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int        @id @default(autoincrement())
  name            String
  email           String     @unique
  password        String
  tasks           Task[]
  categories      Category[]
  klmsConnectedAt DateTime?
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   Int
  tasks    Task[]
  parent   Category?  @relation("CategoryToParent", fields: [parentId], references: [id], onDelete: Cascade)
  parentId Int?
  children Category[] @relation("CategoryToParent")

  @@unique([userId, parentId, name])
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id                   Int            @id @default(autoincrement())
  title                String
  done                 Boolean        @default(false)
  createdAt            DateTime       @default(now())
  dueDate              DateTime?
  recurrenceType       RecurrenceType @default(NONE)
  recurrenceDaysOfWeek Int[]          @default([])
  recurrenceDayOfMonth Int?
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               Int
  categories           Category[]
  klmsId               String?

  @@unique([userId, klmsId])
}
